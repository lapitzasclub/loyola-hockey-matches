{
  "name": "loyola-hockey-matches",
  "version": "1.8.1",
  "description": "App híbrida para mostrar partidos de Loyola Indautxu A (scrapping web FVP)",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "lint": "eslint \"www/**/*.js\"",
    "cap:copy": "npx cap copy",
    "cap:sync": "npx cap sync",
    "android:sync": "npm run build && npx cap sync android",
    "android:run": "npm run android:sync && npx cap run android",
    "android:open": "npx cap open android",
    "cf:dev": "npm run build && npx wrangler pages dev dist",
    "cf:deploy": "npm run build && npx wrangler pages deploy dist"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.4.3",
    "@capacitor/status-bar": "^7.0.3",
    "@capgo/capacitor-navigation-bar": "^7.1.33",
    "chart.js": "^4.5.1",
    "express": "^5.1.0",
    "http-proxy": "^1.18.1",
    "http-proxy-middleware": "^3.0.5",
    "jquery": "^4.0.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "browser-sync": "^3.0.4",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "live-server": "^1.2.2",
    "nodemon": "^3.1.10",
    "vite": "^7.3.1"
  }
}
